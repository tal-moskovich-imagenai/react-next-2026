---
// Dev → iframe the Slidev dev server on :3030
// Prod → serve the built Slidev output we copy into public/slides/
const slidesUrl = import.meta.env.PUBLIC_SLIDES_URL
  ?? (import.meta.env.DEV ? 'http://localhost:3030' : '/slides/')
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Presentation — React Runs Your Terminal</title>
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="/" class="back-btn">
      <span class="back-arrow">←</span> back
    </a>
    <iframe src={slidesUrl} title="React Runs Your Terminal — Slides" allow="fullscreen" />
    <div class="open-hint">
      <span>having trouble?</span>
      <a href={slidesUrl} target="_blank" rel="noopener">open directly ↗</a>
    </div>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    width: 100%;
    height: 100%;
    background: #090B09;
    font-family: 'JetBrains Mono', monospace;
    overflow: hidden;
  }

  iframe {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .back-btn {
    position: fixed;
    top: 14px;
    left: 14px;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    color: #3CFF7A;
    background: rgba(9, 11, 9, 0.85);
    border: 1px solid #1E3320;
    border-radius: 4px;
    padding: 5px 10px;
    text-decoration: none;
    backdrop-filter: blur(4px);
    transition: border-color 0.2s ease;
  }
  .back-btn:hover { border-color: #3CFF7A; }
  .back-arrow { font-size: 13px; line-height: 1; }

  .open-hint {
    position: fixed;
    bottom: 12px;
    right: 14px;
    z-index: 100;
    font-size: 10px;
    color: #3D5940;
    display: flex;
    gap: 6px;
    align-items: center;
  }
  .open-hint a {
    color: #6B9E6B;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .open-hint a:hover { color: #3CFF7A; }
</style>
